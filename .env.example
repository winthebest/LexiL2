# Sao chép file này thành .env rồi điền giá trị thật.
#
# Từ khi có proxy dev (vite.config.js, ADR-0005), key được đọc ở phía Node và
# KHÔNG vào bundle trình duyệt. Khuyến nghị dùng tên KHÔNG có tiền tố VITE_:
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
DASHSCOPE_WORKSPACE_ID=llm-xxxxxxxxxxxx

# (tùy chọn) ghi đè model mặc định
QWEN_MODEL=qwen3.7-plus
QWEN_VERIFIER_MODEL=qwen3.7-max

# Tương thích ngược: nếu .env của bạn đang dùng các tên có tiền tố VITE_ dưới đây
# thì proxy vẫn đọc được (fallback). Nhưng nên chuyển sang tên ở trên.
# VITE_DASHSCOPE_API_KEY=sk-...
# VITE_DASHSCOPE_WORKSPACE_ID=llm-...
# VITE_QWEN_MODEL=qwen3.7-plus
